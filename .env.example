# ---- Server-only (NEVER commit real values) ----

# Mapbox token used for geocoding via /api/geocode. Keep this unrestricted
# (or restricted to your Vercel/host egress IPs, not by URL).
MAPBOX_ACCESS_TOKEN=

# ---- Client-exposed (NEXT_PUBLIC_*) ----

# Mapbox token used by mapbox-gl in the browser for tile rendering.
# MUST be domain-restricted in the Mapbox dashboard to your production origin(s)
# (e.g. https://nights.example.com). Without restriction, this token can be
# scraped and used to incur charges against your account.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

NEXT_PUBLIC_MAPBOX_MAP_STYLE_DARK=
NEXT_PUBLIC_MAPBOX_MAP_STYLE_LIGHT=

# GraphQL endpoint for the nights API. Must be https in production.
NEXT_PUBLIC_GRAPHQL_URL=

# Comma-separated list of allowed GraphQL hosts (defense against env tampering /
# SSRF). Example: "api.example.com,backup.example.com"
NEXT_PUBLIC_GRAPHQL_ALLOWED_HOSTS=

# Optional analytics/stats script URL (must be https). Loaded with strategy=lazyOnload.
NEXT_PUBLIC_STATS_TRACKING_URL=
